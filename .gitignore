# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE
.idea/
.vscode/
.ipynb_checkpoints

# Local config / secrets
.env

# Datasets (regenerable via scripts/generate_synthetic.py or download_hf.py).
# Anchored to the repo root with a leading slash so it does NOT also match the
# lpr/data/ source package.
/data/
models/recognizer/*_backup.pt

# Web app uploads (runtime, per-user)
app/static/uploads/

# Training artifacts are regenerated by training/evaluation and are noisy while a
# run is in progress, so they are ignored by default. The final trained model,
# KPI report, charts and example gallery ARE shipped in the repo (so the
# dashboard works on a fresh clone) — they are force-added in the release commit:
#   git add -f models/recognizer/crnn.pt models/recognizer/metrics.json \
#              reports/learning_curve.png reports/accuracy_by_length.png \
#              reports/calibration.png reports/predictions.csv \
#              reports/training_history.json reports/examples/
reports/
models/recognizer/
models/**/*_backup.pt
